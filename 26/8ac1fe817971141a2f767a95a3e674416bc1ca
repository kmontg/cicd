            "content": "#!/bin/bash\n# Install script for Gemini CLI Extensions (DevOps) MCP server and skills.\n# Conforms to Google Shell Style Guide (https://google.github.io/styleguide/shellguide.html)\n\nset -eo pipefail\n\nreadonly REPO=\"gemini-cli-extensions/devops\"\nreadonly SERVER_ASSET_PREFIX=\"devops-mcp-server\"\nreadonly SKILLS_ASSET=\"skills.tar.gz\"\n\n# Print an error message to STDERR and exit.\nerr() {\n  echo \"[$(date +'%Y-%m-%dT%H:%M:%S%z')] ERROR: $*\" >&2\n  exit 1\n}\n\n# Print an informational message.\ninfo() {\n  echo \"[$(date +'%Y-%m-%dT%H:%M:%S%z')] INFO: $*\"\n}\n\nmain() {\n  local version=\"\"\n  local pre_release=\"false\"\n\n  while [[ \"$#\" -gt 0 ]]; do\n    case \"${1}\" in\n      -v|--version|--ref|--tag)\n        version=\"${2}\"\n        shift 2\n        ;;\n      --pre-release)\n        pre_release=\"true\"\n        shift 1\n        ;;\n      -h|--help)\n        echo \"Usage: ${0} [--version <tag/ref/release>] [--pre-release]\"\n        exit 0\n        ;;\n      *)\n        err \"Unknown parameter passed: ${1}\"\n        ;;\n    esac\n  done\n\n  local os\n  os=\"$(uname -s | tr '[:upper:]' '[:lower:]')\"\n  local arch\n  arch=\"$(uname -m)\"\n\n  if [[ \"${arch}\" == \"x86_64\" ]]; then\n    arch=\"amd64\"\n  elif [[ \"${arch}\" == \"aarch64\" ]] || [[ \"${arch}\" == \"arm64\" ]]; then\n    arch=\"arm64\"\n  fi\n\n  info \"Determining target version...\"\n\n  if [[ -z \"${version}\" ]]; then\n    local api_url=\"https://api.github.com/repos/${REPO}/releases/latest\"\n    if [[ \"${pre_release}\" == \"true\" ]]; then\n      api_url=\"https://api.github.com/repos/${REPO}/releases\"\n    fi\n    \n    # We assume the first item in the releases array is the latest\n    version=\"$(curl -sL \"${api_url}\" | grep -o '\"tag_name\": \"[^\"]*' | head -n 1 | sed 's/\"tag_name\": \"//')\"\n  fi\n\n  if [[ -z \"${version}\" ]]; then\n    err \"Could not determine version to download.\"\n  fi\n\n  info \"Installing version ${version} for OS: ${os}, Arch: ${arch}...\"\n\n  local server_asset=\"${SERVER_ASSET_PREFIX}-${os}-${arch}\"\n  local download_dir\n  download_dir=\"$(mktemp -d)\"\n\n  # Ensure cleanup on exit\n  trap 'rm -rf \"${download_dir}\"' EXIT\n\n  info \"Downloading assets to temporary directory: ${download_dir}\"\n\n  local server_url=\"https://github.com/${REPO}/releases/download/${version}/${server_asset}\"\n  local skills_url=\"https://github.com/${REPO}/releases/download/${version}/${SKILLS_ASSET}\"\n\n  info \"Downloading MCP Server from: ${server_url}\"\n  if ! curl -sL --fail \"${server_url}\" -o \"${download_dir}/devops-mcp-server\"; then\n    err \"Failed to download ${server_url}. Check if the release and artifact exist.\"\n  fi\n\n  info \"Downloading Skills from: ${skills_url}\"\n  if ! curl -sL --fail \"${skills_url}\" -o \"${download_dir}/${SKILLS_ASSET}\"; then\n    err \"Failed to download ${skills_url}. Check if the release and artifact exist.\"\n  fi\n\n  chmod +x \"${download_dir}/devops-mcp-server\"\n\n  info \"Extracting skills...\"\n  mkdir -p \"${download_dir}/skills\"\n  tar -xzf \"${download_dir}/${SKILLS_ASSET}\" -C \"${download_dir}/skills\"\n\n  local antigravity_dir=\"${HOME}/.antigravity\"\n  local claude_dir=\"${HOME}/.claude\"\n  local codex_dir=\"${HOME}/.codex\"\n  \n  local agents=(\"${antigravity_dir}\" \"${claude_dir}\" \"${codex_dir}\")\n  local agent_dir\n\n  for agent_dir in \"${agents[@]}\"; do\n    info \"Installing components for agent at ${agent_dir}...\"\n    mkdir -p \"${agent_dir}/mcp\" \"${agent_dir}/skills\"\n    \n    cp \"${download_dir}/devops-mcp-server\" \"${agent_dir}/mcp/\"\n    cp -r \"${download_dir}/skills/\"* \"${agent_dir}/skills/\"\n  done\n\n  info \"Installation complete!\"\n}\n\nmain \"$@\"\n",
