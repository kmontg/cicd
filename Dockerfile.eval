# Stage 1: Base Builder Image (Heavy dependencies)
FROM node:lts-trixie-slim AS base-builder

RUN apt-get update && apt-get install -y \
    curl \
    git \
    procps \
    python3 \
    unzip \
    golang-go \
    && rm -rf /var/lib/apt/lists/*

RUN curl -L https://github.com/mikefarah/yq/releases/download/v4.45.1/yq_linux_amd64 -o /usr/bin/yq && \
    chmod +x /usr/bin/yq

# gcloud
RUN curl -sSL https://sdk.cloud.google.com | bash
ENV PATH=${PATH}:/root/google-cloud-sdk/bin

# Terraform
RUN curl -LO https://releases.hashicorp.com/terraform/1.14.8/terraform_1.14.8_linux_amd64.zip \
    && unzip terraform_1.14.8_linux_amd64.zip \
    && mv terraform /usr/local/bin/ \
    && rm terraform_1.14.8_linux_amd64.zip

# Gemini CLI
RUN npm install -g @google/gemini-cli

ENTRYPOINT []

# Stage 2: Build the MCP Server
FROM base-builder AS mcp-builder

WORKDIR /app

COPY cicd-mcp-server/ ./cicd-mcp-server/
COPY lib/ ./lib/
COPY build.sh ./
RUN chmod +x build.sh
RUN ./build.sh

# Stage 3: Final Eval Image
FROM base-builder AS eval-docker-provider

COPY --from=mcp-builder /app/cicd-mcp-server/cicd-mcp-server /usr/local/bin/cicd-mcp-server
RUN mkdir -p /root/.gemini
RUN printf '%b' '{\n\
  "mcpServers": {\n\
    "cicd": {\n\
      "command": "/usr/local/bin/cicd-mcp-server",\n\
      "timeout": 300000,\n\
      "trust": true,\n\
      "env": {\n\
        "GOOGLE_APPLICATION_CREDENTIALS": "$GOOGLE_APPLICATION_CREDENTIALS"\n\
      }\n\
    }\n\
  }\n\
}\n' > /root/.gemini/settings.json

RUN printf '%b' '{\n\
  "/": "TRUST_PARENT"\n\
}\n' > /root/.gemini/trustedFolders.json

ENV HOME=/root

CMD ["sh"]
